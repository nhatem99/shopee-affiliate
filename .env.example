# ────────────────────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────────────────────
APP_NAME="Mã Giảm Giá"
APP_ENV=local                   # local | production | testing
APP_KEY=                        # Run: php artisan key:generate
APP_DEBUG=true                  # Set false in production
APP_URL=http://localhost:8000   # Public URL (used in emails, links)

APP_LOCALE=vi
APP_FALLBACK_LOCALE=vi
APP_FAKER_LOCALE=vi_VN

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12                # Increase to 14+ in production

# ────────────────────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack               # stack | single | daily | stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                 # debug | info | warning | error (use info/error in prod)

# ────────────────────────────────────────────────────────────────────────────
# DATABASE
# ────────────────────────────────────────────────────────────────────────────
# Local development uses SQLite (zero config)
DB_CONNECTION=sqlite

# For production with MySQL/PostgreSQL, comment out sqlite and use below:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=shopee_affiliate
# DB_USERNAME=root
# DB_PASSWORD=

# ────────────────────────────────────────────────────────────────────────────
# SESSION & CACHE & QUEUE
# ────────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database         # file | database | redis | cookie
SESSION_LIFETIME=120            # Minutes until session expires
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database            # database | redis | array | file
QUEUE_CONNECTION=database       # sync | database | redis (use redis in production)

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ────────────────────────────────────────────────────────────────────────────
# REDIS (optional — improves performance for cache/queue/session in production)
# ────────────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ────────────────────────────────────────────────────────────────────────────
# MAIL
# ────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=log                 # log (dev) | smtp | sendmail | ses | mailgun
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@magiam.vn"
MAIL_FROM_NAME="${APP_NAME}"

# ────────────────────────────────────────────────────────────────────────────
# SHOPEE AFFILIATE API
# Credentials are stored in the api_configs table (managed via Admin → Cấu hình API).
# These env vars are fallbacks for local dev if no DB record exists.
# Get credentials from: https://open.shopee.com/
# ────────────────────────────────────────────────────────────────────────────
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
SHOPEE_PARTNER_ID=

# ────────────────────────────────────────────────────────────────────────────
# ACCESSTRADE API
# Used to generate affiliate tracking links and calculate cashback rates.
# Get API key from: https://accesstrade.vn/
# ────────────────────────────────────────────────────────────────────────────
ACCESS_TRADE_API_KEY=

# ────────────────────────────────────────────────────────────────────────────
# VITE (frontend build)
# ────────────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

# ────────────────────────────────────────────────────────────────────────────
# AWS S3 (optional — for storing product images in production)
# ────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
